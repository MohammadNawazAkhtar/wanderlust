<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title></title>
</head>
<body>
  <h1>Listings:</h1>
  <ul>
    <% for(listing of data){ %>
    <li>
      <a href="/listings/<%= listing._id %> " >
        <%= listing.title %>
      </a>
    </li>
    <% } %>
  </ul>
  <form method="GET" action="/listings/new">
    <button>Add New Listing</button>
  </form>
</body>
</html>